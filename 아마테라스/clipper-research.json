{
	"schemaVersion": "0.1.0",
	"name": "🔬 Research (raw/research)",
	"behavior": "create",
	"noteContentFormat": "## 초록 (Abstract)\n\n{{description}}\n\n## 본문\n\n{{content}}\n\n## 핵심 발견\n\n<!-- 주요 결론 -->\n\n## Proposition T 연관성\n\n<!-- T의 제안과 어떻게 연결되는가 -->",
	"properties": [
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "type",
			"value": "research",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "author",
			"value": "{{author|split:\", \"|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "published",
			"value": "{{published}}",
			"type": "date"
		},
		{
			"name": "clipped",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "tags",
			"value": "raw research",
			"type": "multitext"
		},
		{
			"name": "status",
			"value": "raw",
			"type": "text"
		}
	],
	"triggers": [],
	"noteNameFormat": "{{date:YYYY-MM-DD}}_{{title}}",
	"path": "raw/research"
}
