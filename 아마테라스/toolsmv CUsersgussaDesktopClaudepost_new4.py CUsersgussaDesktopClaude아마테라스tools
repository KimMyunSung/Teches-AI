NUM_WORDS = sorted(WORD_MAP.keys(), key=len, reverse=True)

def solve_challenge(text):
    clean = re.sub(r'[^a-zA-Z]', '', text).lower()
    values = []
    i = 0
    while i < len(clean):
        matched = False
        for word in NUM_WORDS:
            if clean[i:i+len(word)] == word:
                values.append(WORD_MAP[word])
                i += len(word)
                matched = True
                break
        if not matched:
            i += 1
    if not values:
        return None
    merged = []
    i = 0
    while i < len(values):
        v = values[i]
        if v in [20,30,40,50,60,70,80,90] and i+1 < len(values) and 1 <= values[i+1] <= 9:
            merged.append(v + values[i+1])
            i += 2
        else:
            merged.append(v)
            i += 1
    # clean text로 빼기 감지 (공백/특수문자 제거 후)
    subtract = any(x in clean for x in ['reduc','decreas','minus','subtract','fewer','loss','slow','shed','molt'])
    if subtract and len(merged) >= 2:
        return f'{merged[0] - merged[1]:.2f}'
    return f'{sum(merged):.2f}'

def api(method, path, body=None):
    url = BASE + path
    data = json.dumps(body).encode('utf-8') if body else None
    req = urllib.request.Request(url, data=data, method=method, headers={
        'Authorization': f'Bearer {API_KEY}',
        'Content-Type': 'application/json'
    })
    try:
        with urllib.request.urlopen(req, timeout=20, context=ctx) as r:
            return json.loads(r.read().decode('utf-8'))
    except urllib.error.HTTPError as e:
        return {'error': e.code, 'msg': e.read().decode('utf-8', errors='replace')[:200]}

def post_comment(post_id, content, label):
    resp = api('POST', f'/posts/{post_id}/comments', {'content': content})
    if 'error' in resp:
        print(f'ERR {label}: {resp}')
        return
    comment = resp.get('comment', {})
    cid = comment.get('id','')[:8]
    vc = comment.get('verification', {})
    if not vc:
        print(f'OK {label}: comment={cid}')
        return
    challenge = vc['challenge_text']
    answer = solve_challenge(challenge)
    print(f'CHALLENGE {label}: {challenge[:100]}')
    print(f'ANSWER {label}: {answer}')
    if not answer:
        print(f'UNSOLVABLE {label}')
        return
    vresp = api('POST', '/verify', {'verification_code': vc['verification_code'], 'answer': answer})
    if vresp.get('success'):
        print(f'VERIFIED {label}: comment={cid} ans={answer}')
    else:
        print(f'WRONG {label}: ans={answer} hint={str(vresp)[:150]}')

